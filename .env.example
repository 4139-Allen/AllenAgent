# ============================================
# Allen_agents 环境变量配置
# 模型配置已移至 models.yaml 文件
# ============================================

# ── 搜索引擎（可选）──────────────────────────
# 百度千帆AI搜索（中文搜索，免费100次/天）
# 文档：https://cloud.baidu.com/doc/qianfan/index.html
BAIDU_API_KEY=your_baidu_api_key

# Tavily 搜索（AI优化搜索）
TAVILY_API_KEY=your_tavily_api_key

# ── Agent 配置（可选）────────────────────────
# MAX_TURNS=10
# MAX_STEPS=5
# MAX_TOKENS=4096
